# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=f2b_portal
DB_SSLMODE=disable

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production

# Server
PORT=8080

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin bootstrap (optional, created/updated on server startup)
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=
ADMIN_PHONE=
ADMIN_PASSWORD=

# Novelty tuning (optional)
NOVELTY_TRUST_ALPHA=0.15
NOVELTY_FS_WEIGHT_HARVEST=0.5
NOVELTY_FS_WEIGHT_DISTANCE=0.3
NOVELTY_FS_WEIGHT_STORAGE=0.2
NOVELTY_RANK_WEIGHT_RELEVANCE=0.4
NOVELTY_RANK_WEIGHT_PRICE=0.25
NOVELTY_RANK_WEIGHT_EQUITY=0.35
